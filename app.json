{
  "expo": {
    "name": "GraceNote",
    "slug": "gracenote",
    "version": "1.0.0",
    "scheme": "gracenote",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.gracenote.app",
      "supportsTablet": true,

      "infoPlist": {
        "NSCameraUsageDescription": "GraceNote usa a câmera para adicionar fotos como capa.",
        "NSPhotoLibraryUsageDescription": "GraceNote acessa sua galeria para adicionar imagens como capa."
      }
    },
    "android": {
      "package": "com.gracenote.app",
      "adaptiveIcon": {
        "backgroundColor": "#FAFAF9",
        "foregroundImage": "./assets/icon.png"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "extra": {
      "supabaseUrl": "https://eadeptsjowlusbvphwzb.supabase.co",
      "supabaseAnonKey": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVhZGVwdHNqb3dsdXNidnBod3piIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODEwMDY1NTMsImV4cCI6MjA5NjU4MjU1M30.-Zq8DC413jZ40J_MKJdphbUk5Z1Sj5VASbYJVkKnYfI",
      "router": {},
      "eas": {
        "projectId": "ea4ad3d5-712e-411d-ba61-605985cc026b"
      }
    },
    "experiments": {
      "typedRoutes": true
    },
    "web": {
